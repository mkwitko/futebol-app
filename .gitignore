*.tsbuildinfo

# generated native folders
/ios
/android

# Kubb — gerado a partir de openapi.json (pnpm gen:api). Fonte versionada é o
# openapi.json na raiz; o código gerado não é commitado (grande, conflita em merge).
src/api/generated/

# jest
coverage/
/.pnp.*

# env local
.env
.env.local

# Firebase native config (contêm identificadores do projeto) — nunca comitar.
google-services.json
GoogleService-Info.plist
